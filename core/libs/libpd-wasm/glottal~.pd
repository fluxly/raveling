#N canvas 20 44 700 540 12;
#X text 10 8 glottal~ - pitch \, amplitude and voice quality analysis;
#X text 10 22 Outlets: 0=frequency(Hz) 1=intensity(0-1) 2=loudness(0-1) 3=tenseness(0-1) 4=F0(Hz) 5=voiced(0/1);
#X text 10 36 Requires: sigmund~ from ELSE library;
#X obj 58 75 inlet~;
#X obj 58 118 sigmund~;
#X obj 240 118 env~ 256;
#X obj 240 155 expr ($f1 - 40) / 55;
#X obj 240 185 clip 0 1;
#X obj 370 118 env~ 4096;
#X obj 370 155 expr ($f1 - 40) / 55;
#X obj 370 185 clip 0 1;
#X obj 490 118 hip~ 1000;
#X obj 570 118 lop~ 1000;
#X obj 490 158 env~ 512;
#X obj 570 158 env~ 512;
#X obj 510 205 expr ($f1 - $f2 + 20) / 15;
#X obj 510 240 clip 0 1;
#X obj 155 155 > 50;
#X obj 58 158 spigot;
#X obj 510 278 spigot;
#X text 10 320 Calibration:;
#X text 10 334 intensity/loudness: env~ outputs 0-100dB (100=full scale). Adjust -40 and /55 to match your mic level.;
#X text 10 348 tenseness: adjust +20 and /15 in expr. Typical tilt range is -25 (breathy) to -5 (modal) dB.;
#X text 10 362 voiced gate: adjust the 50 in [> 50] to set the silence threshold (in dB \, 0-100 scale).;
#X obj 58 460 outlet;
#X obj 170 460 outlet;
#X obj 280 460 outlet;
#X obj 390 460 outlet;
#X obj 480 460 outlet;
#X obj 570 460 outlet;
#X text 50 476 frequency;
#X text 162 476 intensity;
#X text 272 476 loudness;
#X text 382 476 tenseness;
#X text 476 476 F0;
#X text 563 476 voiced;
#X connect 3 0 4 0;
#X connect 3 0 5 0;
#X connect 3 0 8 0;
#X connect 3 0 11 0;
#X connect 3 0 12 0;
#X connect 4 0 18 0;
#X connect 5 0 6 0;
#X connect 5 0 17 0;
#X connect 6 0 7 0;
#X connect 7 0 25 0;
#X connect 8 0 9 0;
#X connect 9 0 10 0;
#X connect 10 0 26 0;
#X connect 11 0 13 0;
#X connect 12 0 14 0;
#X connect 13 0 15 0;
#X connect 14 0 15 1;
#X connect 15 0 16 0;
#X connect 16 0 19 0;
#X connect 17 0 18 1;
#X connect 17 0 19 1;
#X connect 17 0 29 0;
#X connect 18 0 24 0;
#X connect 18 0 28 0;
#X connect 19 0 27 0;
