{
    "$schema":     "../gen/schemas/desktop-schema.json",
    "identifier":  "default",
    "description": "Default capability set for Hoarder's Little Helper",
    "windows":     ["main"],
    "permissions": [
        "core:default",
        "sql:allow-execute",
        "sql:allow-select",
        "sql:allow-load",
        "sql:allow-close",
        "dialog:allow-open",
        "fs:allow-read-file",
        "fs:allow-write-file",
        "fs:allow-mkdir",
        "fs:allow-read-dir",
        "fs:scope-appdata-recursive"
    ]
}
