{
    "$schema":     "https://schema.tauri.app/config/2",
    "productName": "Hoarder's Little Helper",
    "version":     "0.1.0",
    "identifier":  "com.raveling.hoarders-little-helper",
    "build": {
        "frontendDist":       "../dist",
        "devUrl":             "http://localhost:3100",
        "beforeDevCommand":   "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "windows": [
            {
                "label":       "main",
                "title":       "Hoarder's Little Helper",
                "width":       1280,
                "height":      840,
                "minWidth":    960,
                "minHeight":   640,
                "decorations": true,
                "resizable":   true,
                "center":      true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active":  true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "sql": {}
    }
}
