#N canvas 92 130 1121 647 tract~ 0;
#X text 10 8 tract~ - bandpass formant estimation -> tongue position;
#X text 10 22 Inlets: 0=audio~ 1=F0-Hz(reserved) 2=voiced(0/1);
#X text 10 36 Outlets: 0=tongue.index(12-29) 1=tongue.diam(2.05-3.5);
#X obj 50 72 inlet~;
#X obj 220 72 inlet;
#X obj 380 72 inlet;
#X obj 380 105 select 0 1;
#X text 220 88 F0 reserved;
#X text 10 55 F1 bank (250-850Hz) -> tongue.diam;
#X text 360 55 F2 bank (900-2400Hz) -> tongue.index;
#X obj 30 145 bp~ 300 5;
#X obj 120 145 bp~ 550 5;
#X obj 210 145 bp~ 850 5;
#X obj 30 180 env~ 512;
#X obj 120 180 env~ 512;
#X obj 210 180 env~ 512;
#X obj 60 220 expr (300*$f1 + 550*$f2 + 850*$f3) / ($f1 + $f2 + $f3 + 0.001);
#X obj 60 258 f;
#X obj 60 288 pack f 80;
#X obj 60 318 line;
#X obj 60 348 expr ($f1 - 250) * 0.00264 + 2.05;
#X obj 60 378 clip 2.05 3.5;
#X obj 390 145 bp~ 900 5;
#X obj 480 145 bp~ 1500 5;
#X obj 570 145 bp~ 2400 5;
#X obj 390 180 env~ 512;
#X obj 480 180 env~ 512;
#X obj 570 180 env~ 512;
#X obj 420 220 expr (900*$f1 + 1500*$f2 + 2400*$f3) / ($f1 + $f2 + $f3 + 0.001);
#X obj 420 258 f;
#X obj 420 288 pack f 80;
#X obj 420 318 line;
#X obj 420 348 expr ($f1 - 700) * 0.010625 + 12;
#X obj 420 378 clip 12 29;
#X obj 420 448 outlet;
#X obj 60 448 outlet;
